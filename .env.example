# ===== Copia este archivo a ".env.local" y llena los valores =====

# Tu llave de Anthropic (Claude). Sácala de https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar. Sonnet: buena precisión y barato (recomendado).
# Si quieres máxima precisión y no te importa gastar más: claude-opus-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Base de datos.
# - En tu compu (desarrollo): deja "file:local.db" (se crea un archivo local).
# - En producción (Vercel): pega aquí la URL de Turso (empieza con libsql://...).
TURSO_DATABASE_URL=file:local.db
# El token solo se necesita con Turso (en producción). En local déjalo vacío.
TURSO_AUTH_TOKEN=

# Contraseña para entrar a la app (es pública en internet, esto evita que entren extraños).
# Pon la que quieras, algo que solo tú sepas.
APP_PASSWORD=cambiame

# Llave de USDA FoodData Central (GRATIS) para nutrición precisa por ingrediente.
# Sácala en https://fdc.nal.usda.gov/api-key-signup (1 min). DEMO_KEY funciona con límite bajo.
USDA_API_KEY=DEMO_KEY
